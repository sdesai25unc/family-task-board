# ─────────────────────────────────────────────────────────────────────────────
# Family Task Board — environment variables
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# Vite only exposes variables prefixed with VITE_ to the browser. Anything
# without that prefix stays server-side (Edge Functions) and is never shipped
# to the client.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED NOW (Phases 1–3: core app) ──────────────────────────────────────

# Supabase project URL, e.g. https://abcd1234.supabase.co
# Supabase dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=

# Supabase "anon public" API key (safe to expose to the browser).
# Supabase dashboard → Project Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=


# ── REQUIRED LATER (Phase 5: Web Push) ───────────────────────────────────────

# Public VAPID key (safe to expose to the browser). Generated with web-push.
VITE_VAPID_PUBLIC_KEY=

# Private VAPID key — SERVER ONLY, never expose. Used by the Edge Function to
# sign push messages. Set as a Supabase Edge Function secret, not in client env.
VAPID_PRIVATE_KEY=

# Contact subject for VAPID (a mailto: or https: URL identifying the sender).
VAPID_SUBJECT=mailto:weslimemphis@gmail.com


# ── REQUIRED LATER (Phases 6–7: cron + email fallback) ───────────────────────

# Supabase service-role key — SERVER ONLY, full DB access, NEVER expose to the
# browser or commit. Used by the daily cron Edge Function.
# Supabase dashboard → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key — SERVER ONLY. For email fallback when a member has no push sub.
# resend.com → API Keys
RESEND_API_KEY=

# The "from" address Resend sends as. Until you verify a domain, Resend allows
# onboarding@resend.dev for testing.
RESEND_FROM_EMAIL=onboarding@resend.dev
